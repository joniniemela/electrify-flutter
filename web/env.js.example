// Copy this file to web/env.js (which is gitignored) and replace the placeholder
// with your real Google Maps JavaScript API key.
//
// This is a SEPARATE key from the Android/iOS Maps SDK keys: enable
// "Maps JavaScript API" in Google Cloud Console and create a key restricted
// to your web origins (HTTP referrers).
//
// The init script in web/index.html injects the Maps JS API tag based on this
// value, before flutter_bootstrap.js starts loading the Flutter app.
window.MAPS_API_KEY = "YOUR_WEB_KEY_HERE";
